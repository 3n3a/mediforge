# Worker connection
WORKER_HOST=192.168.1.100
WORKER_USER=mediforge

# Worker paths (defaults shown)
# WORKER_INBOX=/Users/mediforge/media-pipeline/inbox
# WORKER_OUTBOX=/Users/mediforge/media-pipeline/outbox
# WORKER_ENCODE_SCRIPT=/Users/mediforge/media-pipeline/encode.sh

# Master inbox — directory to watch for new media files
MASTER_INBOX=/mnt/user/media/inbox

# Jellyfin library — where encoded files are placed
JELLYFIN_LIBRARY=/mnt/user/media/movies

# SSH key path on the host
SSH_KEY_PATH=/root/.ssh/id_ed25519

# Archive — keep original master files instead of deleting after encode
# Set ARCHIVE_ENABLED to any value to enable archiving
# ARCHIVE_ENABLED=true
# ARCHIVE_DIR=/mnt/user/media/archive

# Settling delay in seconds (time to wait for file to finish copying)
# SETTLE_DELAY=5
