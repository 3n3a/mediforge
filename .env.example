# -------------------- Required --------------------

# Worker HTTP endpoint (no trailing slash)
WORKER_URL=http://mac-mini.lan:8080

# Shared secret — must match WORKER_TOKEN on the worker
# Generate with: openssl rand -hex 32
WORKER_TOKEN=replace-me

# Host paths for docker-compose volume mounts
MEDIA_TV=/mnt/user/media/tv
MEDIA_MOVIES=/mnt/user/media/movies

# -------------------- Optional --------------------

# Named libraries (container paths). Format: name:/path,name:/path
# docker-compose.yml sets this from the MEDIA_TV/MEDIA_MOVIES mounts above.
# Override here if you add more libraries.
# MEDIA_LIBRARIES=tv:/media/tv,movies:/media/movies

# How aggressively to retry a failed file. attempts >= MAX_RETRIES marks the file
# failed_permanent; it won't be retried until you run `mediforge jobs retry <path>`
# or re-dispatch with --force.
# MAX_RETRIES=2

# Archive mode. Currently only 'replace' is implemented:
# encoded file takes the original's place; a hidden .original sidecar is created
# during the swap and removed once the encoded file is durable on disk.
# ARCHIVE_MODE=replace

# Probe cache database file
# MEDIFORGE_DB=/var/lib/mediforge/mediforge.db

# HTTP timeouts (Go duration syntax: 30m, 6h, 90s, etc.)
# HTTP_TIMEOUT_UPLOAD=30m
# HTTP_TIMEOUT_ENCODE=6h

# Video extensions to consider for encoding (lowercase, comma-separated, no dots)
# MEDIA_EXTENSIONS=mkv,avi,mp4,mov,ts,wmv,flv,m4v,webm

# debug|info|warn|error
# LOG_LEVEL=info
# LOG_FORMAT=text   # or 'json'

# -------------------- Jellyfin refresh trigger --------------------

# Enable to POST /Library/Refresh after a successful per-library run.
# JELLYFIN_INTEGRATION_ENABLED=false
# JELLYFIN_URL=http://jellyfin.lan:8096
# JELLYFIN_API_KEY=replace-me
